{
  "name": "@dag-flow/cli",
  "version": "0.1.0",
  "description": "dag-flow CLI — multi-runtime skill compiler and installer (local install via npm link, not published in V1).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dag": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "manifests",
    "hooks"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "golden-gate:antigravity": "cd .. && ./cli/scripts/verify-antigravity-parity.sh",
    "golden-gate:cursor": "cd .. && ./cli/scripts/verify-cursor-parity.sh",
    "golden-gate": "npm run build && npm link && npm run golden-gate:antigravity && npm run golden-gate:cursor",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@jest/globals": "30.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.2"
  }
}
