{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/caveman-session-start.mjs",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/caveman-before-submit.mjs",
        "timeout": 8
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/tool-routing.mjs",
        "timeout": 10,
        "matcher": "Shell|Read|Grep|WebFetch|Task|MCP:"
      }
    ],
    "postToolUse": [
      {
        "command": "context-mode hook cursor posttooluse"
      }
    ],
    "stop": [
      {
        "command": "context-mode hook cursor stop"
      }
    ]
  }
}
