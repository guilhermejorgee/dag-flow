{
  "assertions": [
    { "type": "file_exists", "path": "CONTEXT.md" },
    { "type": "glob_exists", "pattern": ".specs/features/*/design.md" },
    { "type": "glob_exists", "pattern": ".specs/dags/*.md" },
    { "type": "glob_grep", "glob": ".specs/dags/*.md",
      "pattern": "agy --dangerously-skip-permissions" },
    { "type": "glob_grep", "glob": ".specs/features/*/design.md",
      "pattern": "[Rr]edis|[Rr]ate.?[Ll]imit|throttl" },
    { "type": "socratic_turns", "min_turns": 1,
      "comment": "Brownfield: agent must ask about existing infra before proceeding" },
    { "type": "token_lte", "phase": "discovery", "threshold": 5000 },
    { "type": "token_lte", "phase": "specify", "threshold": 12000 },
    { "type": "skill_in_set", "expected": ["security-review", "backend-patterns", "api-design"] }
  ]
}
